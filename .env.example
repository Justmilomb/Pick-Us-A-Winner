# Environment Variables for Giveaway Engine

# Apify API Token
# Get your token from: https://console.apify.com/account#/integrations
APIFY_TOKEN=your_apify_token_here

# SMTP Configuration for sending emails
# IMPORTANT:
# - SMTP_PASS must be an app password (not your account login password)
# - Keep SMTP_FROM the same as SMTP_USER unless your provider explicitly allows aliases
#
# iCloud Mail example:
# SMTP_HOST=smtp.mail.me.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@icloud.com
# SMTP_PASS=your_icloud_app_specific_password
# SMTP_FROM=you@icloud.com
#
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_google_app_password
# SMTP_FROM=you@gmail.com
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@icloud.com
SMTP_PASS=your_app_specific_password
SMTP_FROM=your_email@icloud.com
SMTP_FROM_NAME=PickUsAWinner Support
SMTP_REPLY_TO=support@pickusawinner.com

# Admin API Key - Required for admin endpoints (analytics, token generation)
# Generate a secure random string
ADMIN_API_KEY=your_secure_admin_key_here

# Contact form - where submissions are sent (default: support@pickusawinner.com)
CONTACT_EMAIL=support@pickusawinner.com

# Optional: Base URL for email links (auto-detected if not set)
BASE_URL=https://your-domain.com

# Optional: Port to run the server on (default: 5000)
PORT=5000
